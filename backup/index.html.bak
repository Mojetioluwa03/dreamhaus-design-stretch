<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Design Stretch</title>
<meta name="description" content="Design Stretch is a 6-hour intensive design learning experience by DreamHaus for junior and intermediate designers. Saturday, 8 August, 7AM–1PM." />
<meta property="og:title" content="Design Stretch — by DreamHaus" />
<meta property="og:description" content="Stretch your thinking. Stretch your process. Stretch your possibilities. A 6-hour intensive for designers ready to go further." />

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Archivo+Expanded:wght@700;800;900&family=Archivo:ital,wght@0,400;0,500;0,600;0,700;0,800;1,500&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">

<script src="https://cdn.tailwindcss.com"></script>
<script>
  tailwind.config = {
    theme: {
      extend: {
        colors: {
          paper: '#FFFFFF',
          ink: '#191713',
          signal: '#FF4014',
          'tape-blue': '#2A3EFF',
          'measure-yellow': '#FFC83D',
        },
        fontFamily: {
          display: ['Archivo Expanded', 'sans-serif'],
          sans: ['Archivo', 'sans-serif'],
          mono: ['Space Mono', 'monospace'],
        },
      },
    },
  };
</script>

<style>
  :root{
    --paper: #FFFFFF;
    --paper-2: #F7F6F3;
    --ink: #191713;
    --ink-75: rgba(0, 0, 0, 0.7);
    --ink-70: rgba(25,23,19,0.7);
    --ink-45: rgba(25,23,19,0.45);
    --ink-15: rgba(25,23,19,0.15);
    --signal: #E53535;
    --tape-blue: #2A3EFF;
    --measure-yello:#ec5151;
  }

  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  @media (prefers-reduced-motion: reduce){
    html { scroll-behavior: auto; }
    *, *::before, *::after { animation-duration: 0.001ms !important; animation-iteration-count: 1 !important; transition-duration: 0.001ms !important; scroll-behavior: auto !important; }
  }

  body{
    margin:0;
    background: var(--paper);
    color: var(--ink);
    font-family: 'Archivo', sans-serif;
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
  }

  .font-display{
    font-family: 'Archivo Expanded', sans-serif;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.92;
  }
  .font-mono{ font-family: 'Space Mono', monospace; }

  ::selection{ background: var(--signal); color: var(--paper); }

  /* focus visibility */
  a:focus-visible, button:focus-visible, summary:focus-visible {
    outline: 3px solid var(--tape-blue);
    outline-offset: 3px;
  }


  /* ---------- Grid backdrop ---------- */
  .grid-backdrop{
    background-image:
      linear-gradient(var(--ink-15) 1px, transparent 1px),
      linear-gradient(90deg, var(--ink-15) 1px, transparent 1px);
    background-size: 64px 64px;
  }

  /* ---------- Nav ---------- */
  .nav{
    position: sticky; top:0; z-index: 50;
    background: rgba(255,255,255,0.88);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--ink-15);
  }

  .btn-primary{
    display:inline-flex; align-items:center; gap:0.5rem;
    background: var(--signal);
    color: var(--paper);
    font-family:'Archivo', sans-serif; font-weight:700;
    padding: 0.85rem 1.6rem;
    border-radius: 999px;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    font-size: 0.85rem;
    transition: transform .35s cubic-bezier(.2,.9,.25,1), box-shadow .35s ease, background .35s ease;
    box-shadow: 0 0 0 0 rgba(255,64,20,0);
    white-space: nowrap;
  }
  .btn-primary:hover{
    transform: scaleX(1.06);
    background: #121800;
  }
  .btn-primary:active{ transform: scaleX(0.97); }

  .btn-ghost{
    display:inline-flex; align-items:center; gap:0.4rem;
    font-family:'Space Mono', monospace;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--ink);
    border-bottom: 1px solid var(--ink);
    padding-bottom: 2px;
    transition: color .25s ease, border-color .25s ease, gap .25s ease;
  }
  .btn-ghost:hover{ color: var(--signal); border-color: var(--signal); gap: 0.65rem; }

  /* ---------- Hero word ---------- */
  .stretch-word{
    display:inline-block;
    transition: color .5s ease;
  }

  .hero-highlight{
    color: var(--signal);
    font-weight: 700;
  }

  .eyebrow{
    font-family:'Space Mono', monospace;
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-70);
    display:inline-flex;
    align-items:center;
    gap: 0.6rem;
  }
  .eyebrow::before{
    content:"";
    width: 26px; height: 1px; background: var(--ink-45);
  }

  /* reveal on scroll */
  .reveal{ opacity: 0; transform: translateY(28px); transition: opacity .8s ease, transform .8s cubic-bezier(.2,.7,.2,1); }
  .reveal.in{ opacity: 1; transform: translateY(0); }
  .reveal-delay-1{ transition-delay: .08s; }
  .reveal-delay-2{ transition-delay: .16s; }
  .reveal-delay-3{ transition-delay: .24s; }

  /* ---------- who-it's-for stretch list ---------- */
  .who-row{
    position: relative;
    display: flex;
    align-items: baseline;
    gap: 1.1rem;
    padding: 1.35rem 0;
    border-bottom: 1px solid var(--ink-15);
    overflow: hidden;
  }
  .who-row::before{
    content:"";
    position:absolute;
    left:0; top:0;
    width: 3px; height: 100%;
    background: var(--signal);
    transform: scaleY(0);
    transform-origin: bottom;
    transition: transform .45s cubic-bezier(.34,1.56,.64,1);
  }
  .who-row:hover::before{ transform: scaleY(1); }
  .who-num{
    font-family:'Space Mono', monospace;
    font-size: 0.8rem;
    color: var(--ink-45);
    flex-shrink:0;
    width: 1.6rem;
    transition: color .35s ease;
  }
  .who-tag{
    font-family:'Space Mono', monospace;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--signal);
    flex-shrink:0;
    width: 6.5rem;
  }
  .who-word{
    font-family:'Archivo', sans-serif;
    font-weight: 600;
    font-size: clamp(1.05rem, 2vw, 1.5rem);
    letter-spacing: 0;
    transition: transform .5s cubic-bezier(.34,1.56,.64,1), letter-spacing .5s ease, color .35s ease;
    transform-origin: left center;
  }
  .who-row:hover .who-word{
    transform: translateX(10px);
    letter-spacing: 0.01em;
  }
  .who-row:hover .who-num{ color: var(--signal); }
  @media (max-width: 640px){
    .who-row{ flex-wrap: wrap; gap: 0.4rem 1rem; }
    .who-tag{ width: auto; order: 1; }
    .who-num{ order: 0; }
    .who-word{ order: 2; flex-basis: 100%; }
  }

  @media (max-width: 640px){
    .nav > div {
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0.85rem;
      height: auto;
      padding-top: 1rem;
      padding-bottom: 1rem;
    }

    .nav .btn-primary {
      white-space: nowrap;
      font-size: 0.8rem;
      padding: 0.75rem 1rem;
      min-width: auto;
    }

    .btn-mobile-full {
      width: 100%;
      justify-content: center;
      white-space: nowrap;
      text-align: center;
      font-size: 0.8rem;
      padding-left: 1rem;
      padding-right: 1rem;
    }

    header#top {
      padding-top: 1.25rem;
      padding-bottom: 1.5rem;
    }

    header#top h1 {
      font-size: clamp(3rem, 14vw, 4.2rem);
      line-height: 0.96;
      max-width: min(100%, 20rem);
      margin: 0 auto;
      text-align: center;
      word-break: normal;
      overflow-wrap: normal;
      letter-spacing: -0.03em;
    }
    header#top #stretchWord {
      white-space: nowrap;
      display: inline-block;
      margin-top: 0.15rem;
    }
    header#top .hero-copy {
      text-align: center;
      margin-left: auto;
      margin-right: auto;
      max-width: 100%;
    }
    header#top .hero-copy p {
      font-size: 1rem;
      line-height: 1.6;
    }
    header#top .btn-primary {
      font-size: 0.78rem;
    }

    @media (max-width: 520px) {
      header#top h1 {
        font-size: clamp(2rem, 16vw, 3.4rem);
        max-width: min(100%, 20rem);
      }
    }

    details.faq-item summary {
      flex-wrap: wrap;
      align-items: flex-start;
    }
    details.faq-item summary span:first-child {
      min-width: 0;
      flex: 1 1 100%;
    }
    details.faq-item summary .faq-plus {
      margin-top: 0.35rem;
    }
    .faq-body {
      max-width: 100%;
    }
    .btn-mobile-full {
      width: 100%;
      justify-content: center;
      white-space: normal;
      text-align: center;
    }
  }

  /* highlight cards */
  .stretch-card{
    transition: transform .4s cubic-bezier(.2,.85,.2,1), box-shadow .4s ease, border-color .4s ease;
  }
  .stretch-card:hover{
    transform: translateY(-6px) scaleX(1.015);
    border-color: var(--ink);
    box-shadow: 8px 8px 0 var(--ink);
  }

  /* journey rail */
  .journey-item{ position: relative; }
  .journey-num{
    font-family:'Space Mono', monospace;
    font-size: 0.85rem;
    color: var(--ink-45);
    letter-spacing: 0.05em;
  }

  /* faq */
  details.faq-item{ border-bottom: 1px solid var(--ink-15); }
  details.faq-item summary{
    list-style: none;
    cursor: pointer;
    display:flex; align-items:center; justify-content: space-between; gap: 1rem;
    padding: 1.6rem 0;
  }
  details.faq-item summary::-webkit-details-marker{ display:none; }
  .faq-plus{
    flex-shrink:0;
    width: 28px; height: 28px;
    position: relative;
  }
  .faq-plus::before, .faq-plus::after{
    content:""; position:absolute; background: var(--ink);
    transition: transform .3s ease, background .3s ease;
  }
  .faq-plus::before{ top:50%; left:0; width:100%; height:2px; transform: translateY(-50%); }
  .faq-plus::after{ left:50%; top:0; width:2px; height:100%; transform: translateX(-50%); }
  details[open] .faq-plus::after{ transform: translateX(-50%) rotate(90deg); opacity:0; }
  details[open] .faq-plus::before{ background: var(--signal); }
  .faq-body{ padding-bottom: 1.7rem; max-width: 62ch; color: var(--ink-70); }

  /* ticket cards */
  .ticket-card{ transition: transform .3s ease, box-shadow .3s ease; }
  .ticket-card:hover{ transform: translateY(-4px); }

  /* marquee */
  .marquee-track{
    display:flex; width: max-content;
    animation: marquee 26s linear infinite;
  }
  @media (prefers-reduced-motion: reduce){ .marquee-track{ animation: none; } }
  @keyframes marquee{ from{ transform: translateX(0);} to{ transform: translateX(-50%);} }

  ::-webkit-scrollbar{ width: 10px; }
  ::-webkit-scrollbar-track{ background: var(--paper); }
  ::-webkit-scrollbar-thumb{ background: var(--ink-45); border-radius: 10px; }

  .divider-line{ height:1px; background: var(--ink-15); width:100%; }

  .num-badge{
    width: 3.25rem; height:3.25rem; flex-shrink:0;
    border: 1.5px solid var(--ink);
    border-radius: 999px;
    display:flex; align-items:center; justify-content:center;
    font-family:'Space Mono',monospace; font-weight:700; font-size:0.85rem;
  }
</style>
</head>

<body>

<!-- ============ NAV ============ -->
<nav class="nav">
  <div class="max-w-7xl mx-auto px-6 md:px-10 h-20 flex items-center justify-between">
    <a href="#top" class="font-display text-lg md:text-xl tracking-tight flex items-baseline gap-2 normal-case">
      DreamHaus
    </a>
    <a href="#registration-form" class="btn-primary hidden md:inline-flex">Reserve Your Seat</a>
  </div>
</nav>

<!-- ============ HERO ============ -->
<header id="top" class="relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 md:px-10 md:pt-24 pt-16 pb-16 flex flex-col items-center text-center md:items-center md:text-center">
    <h1 class="reveal in w-full max-w-3xl">
      <img
        src="./DreamHaus DS Core.svg"
        alt="Design Stretch"
        class="w-full h-auto block"
      />
    </h1>

    <div class="mt-6 md:mt-8 w-full grid w-xs md:grid-cols-12 gap-8 items-center justify-items-center">
      <p class="md:col-span-8 md:col-start-3 w-md text-lg pt-6 md:text-2xl leading-snug text-[var(--ink-70)] reveal in reveal-delay-1 mx-auto">
        An intensive learning experience designed to help junior and intermediate designers accelerate their design mastery.
      </p>
    </div>

    <br>
    <br>
    <a href="#registration-form" class="btn-primary">Reserve Your Seat</a>
  </div>
</header>

<!-- ============ FACILITATOR ============ -->
<section id="facilitator" class="bg-[var(--paper-2)] max-w-7xl mx-auto px-6 md:px-10 py-24 md:py-32">
  <div class="grid md:grid-cols-12 gap-10 items-start">
    <div class="md:col-span-4 reveal">
      <p class="eyebrow">FACILITATOR</p>
      <h2 class="font-display text-4xl md:text-5xl mt-6">MichaEL Light T.</h2>
      <div class="relative mt-8 max-w-[320px] overflow-hidden ">
        <img src="./Mr Michael BW IMG.png" alt="MichaEL Light T." />
      </div>
    </div>

    <div class="md:col-span-8 reveal reveal-delay-1 ">
      <p class="mt-5 text-[var(--ink-75)] max-w-xl">
        MichaEL Light Tommy is a creative leader working at the intersection of human experience, visual creativity, and technology. With over a decade of experience, he has led high-impact design, research, and creative projects for leading organizations and brands including Honeywell Group, Co-creation Hub (CcHub), Sympli, Ennovate Lab, and KTN–UK Aid.
      </p>
      <p class="mt-5 text-[var(--ink-75)] max-w-xl">
        He currently serves as a User Experience Researcher at YouVersion's Bible App, while also leading DreamHaus as Founder and Creative Director, and co-leading L'Orbe Creative Excellence Initiative, a nonprofit advancing creative excellence and human flourishing across Africa's secondary cities.
      </p>

      <p class="mt-5 text-[var(--ink-75)] max-w-xl">
        MichaEL is widely recognized for designing Minister Dunsin Oyekan's album covers between 2022 and 2024, as well as the cover art for Folabi Nuel's Glory On The Other Side featuring Grammy Award winner Matt Redman. Through Marvelly's God Is My Designer project, his work has reached audiences in more than five countries across Africa and North America.
      </p>

       <p class="mt-5 text-[var(--ink-75)] max-w-xl">
        His work has been featured on CNN Africa, YNaija, and Afrocritik, and he has facilitated training and spoken at platforms including the National Information Technology Development Agency (NITDA), TEDx, the Ogbomoso Digital Economy Summit (ODES), and Google Developer Student Groups (GDSC/GDSG).
      </p>

       <p class="mt-5 text-[var(--ink-75)] max-w-xl">
        Driven by a passion for God, family, creativity, and community, MichaEL is committed to raising a new generation of purpose-driven creatives who design with excellence and contribute meaningfully to society. He lives in Ogbomoso, Nigeria, with his wife, Otobong, and their three children.
      </p>

      </div>
    </div>
  </div>
</section>


<!-- ============ OUTCOMES ============ -->
<section class="max-w-7xl mx-auto px-6 md:px-10 py-24 md:py-32">
  <div class="reveal">
    <p class="eyebrow">What You'll Leave With</p>
    <h2 class="font-display text-4xl md:text-6xl mt-6 max-w-3xl">Leave with more than notes.</h2>
  </div>

  <div class="mt-16 grid md:grid-cols-2 gap-x-14">
    <div class="reveal reveal-delay-1">
      <div class="flex gap-5 py-6 border-b border-[var(--ink-15)]">
        <span class="font-mono text-xs text-[var(--ink-45)] mt-1">/01</span>
        <p class="text-lg">Network with other growing designers.</p>
      </div>
      <div class="flex gap-5 py-6 border-b border-[var(--ink-15)]">
        <span class="font-mono text-xs text-[var(--ink-45)] mt-1">/02</span>
        <p class="text-lg">Learn proven industry strategies.</p>
      </div>
      <div class="flex gap-5 py-6 border-b border-[var(--ink-15)]">
        <span class="font-mono text-xs text-[var(--ink-45)] mt-1">/03</span>
        <p class="text-lg">Gain improved creative and critical thinking skills.</p>
      </div>
    </div>
    <div class="reveal reveal-delay-2">
      <div class="flex gap-5 py-6 border-b border-[var(--ink-15)]">
        <span class="font-mono text-xs text-[var(--ink-45)] mt-1">/04</span>
        <p class="text-lg">Gain practical experience applying design principles.</p>
      </div>
      <div class="flex gap-5 py-6 border-b border-[var(--ink-15)]">
        <span class="font-mono text-xs text-[var(--ink-45)] mt-1">/05</span>
        <p class="text-lg">Get feedback on your design process and decisions.</p>
      </div>
      <div class="flex gap-5 py-6 border-b border-[var(--ink-15)]">
        <span class="font-mono text-xs text-[var(--ink-45)] mt-1">/06</span>
        <p class="text-lg">Gain a stronger understanding of how experienced designers think.</p>
      </div>
    </div>
  </div>
</section>


<!-- ============ DESIGN CHALLENGE ============ -->


<!-- ============ EVENT DETAILS / REGISTRATION ============ -->
<section id="register" class="bg-[var(--paper-2)] max-w-7xl mx-auto px-6 md:px-10 py-24 md:py-32">
  <div class="reveal text-center max-w-2xl mx-auto">
    <p class="eyebrow justify-center">Event Details</p>
    <h2 class="font-display text-5xl md:text-7xl mt-6">DESIGN STRETCH</h2>
  </div>

  <div class="mt-14 grid sm:grid-cols-2 lg:grid-cols-5 gap-4 max-w-5xl mx-auto reveal reveal-delay-2">
    <div class="border border-[var(--ink-15)] rounded-2xl p-6 text-center">
      <svg class="w-5 h-5 mx-auto mb-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
      <p class="font-mono text-[11px] uppercase tracking-widest text-[var(--ink-45)] mb-1">Date</p>
      <p class="font-display text-lg">Sat, 8 Aug</p>
    </div>
    <div class="border border-[var(--ink-15)] rounded-2xl p-6 text-center">
      <svg class="w-5 h-5 mx-auto mb-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      <p class="font-mono text-[11px] uppercase tracking-widest text-[var(--ink-45)] mb-1">Time</p>
      <p class="font-display text-lg">8 AM – 2 PM</p>
    </div>
    <div class="border border-[var(--ink-15)] rounded-2xl p-6 text-center">
      <svg class="w-5 h-5 mx-auto mb-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 22h14"/><path d="M5 2h14"/><path d="M17 22v-4.17a2 2 0 0 0-.59-1.42L12 12l-4.41 4.41A2 2 0 0 0 7 17.83V22"/><path d="M7 2v4.17a2 2 0 0 0 .59 1.42L12 12l4.41-4.41A2 2 0 0 0 17 6.17V2"/></svg>
      <p class="font-mono text-[11px] uppercase tracking-widest text-[var(--ink-45)] mb-1">Duration</p>
      <p class="font-display text-lg">6 Hours</p>
    </div>
    <div class="border border-[var(--ink-15)] rounded-2xl p-6 text-center">
      <svg class="w-5 h-5 mx-auto mb-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0z"/><circle cx="12" cy="10" r="3"/></svg>
      <p class="font-mono text-[11px] uppercase tracking-widest text-[var(--ink-45)] mb-1">Venue</p>
      <p class="font-display text-base leading-tight">DreamHaus</p>
      <p class="font-mono text-[11px] text-[var(--ink-70)] mt-1 leading-snug">Topfloor, Ace Supermarket<br>Isale General, Ogbomoso</p>
    </div>
    <div class="border border-[var(--ink-15)] rounded-2xl p-6 text-center">
      <svg class="w-5 h-5 mx-auto mb-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      <p class="font-mono text-[11px] uppercase tracking-widest text-[var(--ink-45)] mb-1">Audience</p>
      <p class="font-display text-lg">Junior &amp; Intermediate Designers</p>
    </div>
  </div>

  <div class="mt-14 grid md:grid-cols-2 gap-6 max-w-4xl mx-auto reveal reveal-delay-2">
    <div class="ticket-card relative border-2 border-[var(--ink)] rounded-2xl p-8 bg-[var(--measure-yellow)]">
      <!-- <span class="absolute top-6 right-6 font-mono text-[10px] uppercase tracking-widest bg-[var(--ink)] text-[var(--paper)] px-3 py-1 rounded-full">Best Value</span> -->
      <p class="font-mono text-xs uppercase tracking-widest">Early Bird</p>
      <p class="font-display text-5xl mt-3">₦10,000</p>
      <a href="#registration-form" class="btn-primary mt-8 w-full justify-center">Reserve Your Seat</a>
    </div>
    <div class="ticket-card border-2 border-[var(--ink)] rounded-2xl p-8">
      <p class="font-mono text-xs uppercase tracking-widest text-[var(--ink-45)]">Regular</p>
      <p class="font-display text-5xl mt-3">₦15,000</p>
      <a href="#registration-form" class="btn-primary mt-8 w-full justify-center" style="background: var(--ink);">Reserve Your Seat</a>
    </div>
  </div>

  <div id="registration-form" class="mt-24 scroll-mt-24 reveal">
    <div class="text-center max-w-xl mx-auto mb-10">
