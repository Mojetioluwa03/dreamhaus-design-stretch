        width="100%"
        height="1904"
        style="display:block; border:0; max-width:100%;"
        marginheight="0"
        marginwidth="0"
      >Loading…</iframe>
  </div>
</section>


<!-- ============ FAQ ============ -->
<section id="faq" class="max-w-4xl mx-auto px-6 md:px-10 py-24 md:py-32">
  <!-- <div class="reveal mb-12">
    <p class="eyebrow">FAQ</p>
    <h2 class="font-display text-4xl md:text-5xl mt-6">Questions, answered.</h2>
  </div> -->

  <div class="reveal reveal-delay-1">
    <details class="faq-item" open>
      <summary><span class="font-display text-xl md:text-2xl pr-4">Who is Design Stretch for?</span><span class="faq-plus"></span></summary>
      <div class="faq-body">Design Stretch is designed primarily for junior and intermediate designers across different design disciplines.</div>
    </details>
    <details class="faq-item">
      <summary><span class="font-display text-xl md:text-2xl pr-4">Do I need to be a professional designer?</span><span class="faq-plus"></span></summary>
      <div class="faq-body">No. You should have a basic understanding of design and be willing to learn and participate.</div>
    </details>
    <details class="faq-item">
      <summary><span class="font-display text-xl md:text-2xl pr-4">What design discipline is the program for?</span><span class="faq-plus"></span></summary>
      <div class="faq-body">The experience is open to graphic designers, brand designers, UI/UX designers, product designers, and other creatives.</div>
    </details>
    <details class="faq-item">
      <summary><span class="font-display text-xl md:text-2xl pr-4">Is this a lecture or a practical workshop?</span><span class="faq-plus"></span></summary>
      <div class="faq-body">Design Stretch combines guided learning, practical exercises, design challenges, and critique.</div>
    </details>
    <details class="faq-item">
      <summary><span class="font-display text-xl md:text-2xl pr-4">What should I bring?</span><span class="faq-plus"></span></summary>
      <div class="faq-body">Bring your laptop, your design tools, and an open mind.</div>
    </details>
    <details class="faq-item">
      <summary><span class="font-display text-xl md:text-2xl pr-4">How much does it cost?</span><span class="faq-plus"></span></summary>
      <div class="faq-body">Early Bird registration is ₦10,000. Regular registration is ₦15,000.</div>
    </details>
  </div>
</section>

<!-- ============ FINAL CTA ============ -->
<section class="relative bg-[var(--paper-2)] text-[var(--ink)] overflow-hidden border-t border-[var(--ink-15)]">
  <div class="max-w-7xl mx-auto px-6 md:px-10 py-28 md:py-40 text-center reveal">
    <h2 class="font-display text-5xl md:text-7xl mt-6 leading-[0.95]">Your journey to<br>design mastery starts with a <span class="text-[var(--signal)]">stretch</span>.</h2>

    <p class="mt-9 text-lg max-w-xl mx-auto" style="color:rgba(25,23,19,0.7)">
      You don't become a better designer by staying comfortable with the way you've always designed.
    </p>

    <a href="#registration-form" class="btn-primary mt-10 inline-flex text-base px-9 py-4 btn-mobile-full">
      Reserve Your Seat <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
    </a>
  </div>
</section>

<!-- ============ FOOTER ============ -->
<footer class="bg-[var(--paper)] text-[var(--ink)] border-t border-[var(--ink-15)]">
  <div class="max-w-7xl mx-auto px-6 md:px-10 py-10 text-center">
    <p class="font-mono text-xs uppercase tracking-widest" style="color:rgba(25,23,19,0.7)">
      Copyright 2026 - Designed by <span class="font-bold normal-case">DreamHaus</span>
    </p>
  </div>
</footer>

<script>
  // ---------- scroll reveal ----------
  const reveals = document.querySelectorAll('.reveal');
  const io = new IntersectionObserver((entries)=>{
    entries.forEach(e=>{
      if(e.isIntersecting){ e.target.classList.add('in'); io.unobserve(e.target); }
    });
  }, { threshold: 0.12 });
  reveals.forEach(r=>io.observe(r));

  // ---------- reduced motion guard ----------
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if(prefersReduced){
    reveals.forEach(r=>r.classList.add('in'));
  }
</script>

</body>
</html>
